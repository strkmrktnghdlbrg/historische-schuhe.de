# historische-schuhe.de  Apache config (A2 Hosting / cPanel)
# Stand: 2026-07-01

# ---------------------------------------------------------------------------
# 1. HTTPS + non-www → www canonical
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # non-www → www
  RewriteCond %{HTTP_HOST} ^historische-schuhe\.de [NC]
  RewriteRule ^ https://www.historische-schuhe.de%{REQUEST_URI} [R=301,L]
</IfModule>

# ---------------------------------------------------------------------------
# 2. Gzip-Komprimierung
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# ---------------------------------------------------------------------------
# 3. Caching-Header
# ---------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Astro-Assets haben Content-Hash im Dateinamen → 1 Jahr cachen
  <FilesMatch "/_astro/.*\.(css|js|woff2?|jpg|jpeg|png|webp|avif|svg|ico)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Bilder ohne Hash → 1 Woche
  <FilesMatch "\.(jpg|jpeg|png|webp|avif|svg|gif|ico)$">
    ExpiresDefault "access plus 1 week"
  </FilesMatch>

  # HTML → kein Cache (immer frisch)
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------------
# 4. Sicherheits-Header
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
