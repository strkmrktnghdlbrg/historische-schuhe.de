---
import BaseLayout from './BaseLayout.astro';
interface Props { title: string; description: string; noindex?: boolean; }
const { title, description, noindex = false } = Astro.props;
---
<BaseLayout title={title} description={description} noindex={noindex}>
  <section style="padding:56px 0">
    <div class="wrap" style="max-width:820px">
      <h1 style="font-size:42px;margin-bottom:24px">{title}</h1>
      <div class="prose">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
