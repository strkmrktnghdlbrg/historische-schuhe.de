---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { silos } from '../data/silos.ts';
import { getImage } from '../lib/images.ts';
import Figure from '../components/Figure.astro';
import AmazonBoxGrid from '../components/AmazonBoxGrid.astro';

export async function getStaticPaths() {
  const artikel = await getCollection('artikel');
  return artikel.map((a) => ({ params: { slug: a.id }, props: { a, all: artikel } }));
}

const { a, all } = Astro.props;
const { Content } = await render(a);
const sidebar = silos[a.data.silo];
const image = getImage(a.id);

// Verwandte Beiträge: gleicher Silo, gleiche Epochen-Familie bevorzugt.
const fam = (s?: string) => (s ?? '').split('/')[0].trim();
const myFam = fam(a.data.epocheLabel);
const related = all
  .filter((x) => x.id !== a.id && x.data.silo === a.data.silo)
  .map((x) => {
    let score = 0;
    if (myFam && fam(x.data.epocheLabel) === myFam) score += 3;
    if (a.data.epocheLabel && x.data.epocheLabel === a.data.epocheLabel) score += 1;
    if (x.data.type === 'money') score += 1;
    return { x, score };
  })
  .sort((p, q) => q.score - p.score || (Number(q.x.data.featured) - Number(p.x.data.featured)))
  .slice(0, 4)
  .map((r) => r.x);
const dateStr = (a.data.updated ?? a.data.pubDate).toLocaleDateString('de-DE', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<BaseLayout title={`${a.data.title} | historische-schuhe.de`} description={a.data.description} ogType="article">
  <section style="padding:48px 0 64px">
    <div class="wrap art-layout">
      <article>
        <a href={sidebar.hubHref} class="crumb">← {sidebar.label}</a>
        <h1 style="font-size:46px;margin:14px 0 14px;line-height:1.05">{a.data.title}</h1>
        <p class="lede">{a.data.description}</p>
        <div class="art-meta">
          <span>{a.data.icon} {a.data.category}</span>
          <span>·</span>
          <span>{a.data.updated ? 'Aktualisiert' : 'Veröffentlicht'} am {dateStr}</span>
          <span>·</span>
          <span>{a.data.readMin} Min. Lesezeit</span>
        </div>
        {a.data.type === 'money' && (
          <div class="aff-banner">Anzeige: Dieser Beitrag enthält Affiliate-Links. Kaufst du darüber, erhalten wir ggf. eine kleine Provision, der Preis bleibt für dich gleich.</div>
        )}
        {image && <div style="margin-top:26px"><Figure image={image} alt={a.data.title} /></div>}
        <div class="prose" style="margin-top:28px">
          <Content />
        </div>
        {a.data.amazonGroup && <AmazonBoxGrid group={a.data.amazonGroup} />}
        {related.length > 0 && (
          <section class="related" aria-label="Verwandte Beiträge">
            <h2>Verwandte Beiträge</h2>
            <div class="rel-grid">
              {related.map((r) => (
                <a href={`/${r.id}/`} class="rel-card">
                  <span class="rel-ic">{r.data.icon}</span>
                  <span class="rel-tx">
                    <span class="rel-cat">{r.data.category}</span>
                    <span class="rel-ti">{r.data.title}</span>
                  </span>
                </a>
              ))}
            </div>
            <a href={sidebar.hubHref} class="rel-all">Alle Beiträge in {sidebar.label} ansehen →</a>
          </section>
        )}
      </article>
      <aside>
        <div class="side-box">
          <h4>{sidebar.label}</h4>
          <ul>
            {sidebar.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
          <a href="/mittelalterschuhe-vergleich/" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:6px">Zum Vergleich →</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .art-layout{display:grid;grid-template-columns:minmax(0,1fr) 300px;gap:48px;align-items:start}
  .crumb{font-size:13.5px;font-weight:600;color:var(--oxblood)}
  .lede{font-size:19px;color:#5a4634;line-height:1.6;margin-bottom:16px}
  .art-meta{display:flex;flex-wrap:wrap;gap:9px;font-size:13px;color:var(--muted);padding-bottom:18px;border-bottom:1px solid var(--line)}
  .aff-banner{margin-top:22px;background:rgba(176,138,62,.12);border:1px solid var(--line);border-radius:10px;padding:13px 16px;font-size:13px;color:#6a5440}
  aside{position:sticky;top:90px}
  .side-box{background:var(--linen);border:1px solid var(--line);border-radius:14px;padding:22px}
  .side-box h4{font-size:13px;text-transform:uppercase;letter-spacing:.1em;color:var(--saddle);margin-bottom:14px;font-family:'Inter';font-weight:700}
  .side-box ul{list-style:none;margin:0 0 16px;padding:0;display:flex;flex-direction:column;gap:2px}
  .side-box li a{display:block;padding:8px 0;font-size:14px;color:#42342a;border-bottom:1px solid var(--line);transition:.15s}
  .side-box li a:hover{color:var(--oxblood)}
  .related{margin-top:46px;padding-top:30px;border-top:1px solid var(--line)}
  .related h2{font-size:28px;margin-bottom:18px}
  .rel-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .rel-card{display:flex;gap:12px;align-items:center;background:var(--linen);border:1px solid var(--line);border-radius:12px;padding:14px 16px;transition:.18s}
  .rel-card:hover{border-color:#d6c4a6;transform:translateY(-2px);box-shadow:0 12px 28px -18px rgba(60,40,20,.4)}
  .rel-ic{font-size:24px;flex:none}
  .rel-tx{display:flex;flex-direction:column;gap:2px;min-width:0}
  .rel-cat{font-size:11px;font-weight:600;color:var(--brass);text-transform:uppercase;letter-spacing:.06em;font-family:'Inter'}
  .rel-ti{font-family:'Cormorant Garamond';font-size:18px;font-weight:600;color:var(--ink);line-height:1.15}
  .rel-all{display:inline-block;margin-top:16px;font-size:14px;font-weight:600;color:var(--oxblood);font-family:'Inter'}
  @media(max-width:900px){
    .art-layout{grid-template-columns:1fr}
    aside{position:static}
    .rel-grid{grid-template-columns:1fr}
  }
</style>
