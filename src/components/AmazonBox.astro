---
import products from '../data/amazon-products.json';

interface Props {
  asin: string;
  badge?: string;
}
const { asin, badge = 'Anzeige' } = Astro.props;
const p = (products as Record<string, any>)[asin];
---
{p && p.title && (
  <div class="amzbox">
    <span class="amz-badge">{badge}</span>
    <a class="amz-img" href={p.url} target="_blank" rel="sponsored nofollow noopener" aria-label={p.title}>
      {p.image
        ? <img src={p.image} alt={p.title} loading="lazy" width="200" height="200" />
        : <div class="amz-noimg">👞</div>}
    </a>
    <div class="amz-body">
      {p.brand && <div class="amz-brand">{p.brand}</div>}
      <a class="amz-title" href={p.url} target="_blank" rel="sponsored nofollow noopener">{p.title}</a>
      {p.features?.length > 0 && (
        <ul class="amz-feat">
          {p.features.slice(0, 2).map((f: string) => <li>{f}</li>)}
        </ul>
      )}
      <div class="amz-foot">
        <div class="amz-price">
          {p.price || 'Preis bei Amazon'}
          {p.isPrime && <span class="amz-prime">Prime</span>}
        </div>
        <a class="amz-btn" href={p.url} target="_blank" rel="sponsored nofollow noopener">
          Bei Amazon ansehen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </div>
)}

<style>
  .amzbox { position: relative; display: flex; flex-direction: column; background: var(--linen); border: 1px solid var(--line); border-radius: 14px; padding: 22px; height: 100%; transition: .18s; }
  .amzbox:hover { border-color: var(--oxblood); box-shadow: 0 18px 44px -18px rgba(60,40,20,.4); transform: translateY(-3px); }
  .amz-badge { position: absolute; top: 14px; right: 14px; font-size: 11px; font-weight: 700; color: var(--saddle); background: var(--parchment-2); padding: 3px 10px; border-radius: 99px; }
  .amz-img { display: grid; place-items: center; height: 180px; margin-bottom: 16px; }
  .amz-img img { max-height: 180px; max-width: 100%; width: auto; object-fit: contain; mix-blend-mode: multiply; }
  .amz-noimg { width: 120px; height: 120px; display: grid; place-items: center; background: var(--parchment-2); border-radius: 10px; font-size: 44px; }
  .amz-body { display: flex; flex-direction: column; flex: 1; }
  .amz-brand { font-size: 11.5px; font-weight: 700; color: var(--brass); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 5px; }
  .amz-title { font-size: 16px; font-weight: 600; line-height: 1.35; color: var(--ink); font-family: 'Inter', system-ui, sans-serif; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .amz-title:hover { color: var(--oxblood); }
  .amz-feat { list-style: none; margin: 10px 0 0; padding: 0; display: flex; flex-direction: column; gap: 4px; }
  .amz-feat li { font-size: 12.5px; color: #5a4634; line-height: 1.4; padding-left: 14px; position: relative; }
  .amz-feat li::before { content: ""; position: absolute; left: 0; top: 6px; width: 5px; height: 5px; border-radius: 50%; background: var(--patina); }
  .amz-foot { margin-top: auto; padding-top: 16px; }
  .amz-price { font-size: 21px; font-weight: 700; color: var(--ink); font-family: 'Cormorant Garamond', Georgia, serif; display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .amz-prime { font-size: 11px; font-weight: 700; color: #fff; background: var(--oxblood); padding: 2px 8px; border-radius: 99px; font-family: 'Inter', sans-serif; }
  .amz-btn { display: inline-flex; align-items: center; justify-content: center; gap: 7px; width: 100%; background: var(--oxblood); color: var(--linen); font-weight: 600; font-size: 14px; padding: 12px 16px; border-radius: 9px; transition: .15s; font-family: 'Inter', sans-serif; }
  .amz-btn:hover { background: var(--oxblood-glow); }
</style>
